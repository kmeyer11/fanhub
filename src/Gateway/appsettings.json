{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "fixtures-route": {
        "ClusterId": "fixtures-cluster",
        "Match": {
          "Path": "/fixtures/{**catch-all}"
        }
      },
      "teams-route": {
        "ClusterId": "teams-cluster",
        "Match": {
          "Path": "/teams/{**catch-all}"
        }
      },
      "roster-route": {
        "ClusterId": "roster-cluster",
        "Match": {
          "Path": "/roster/{**catch-all}"
        }
      },
      "standings-route": {
        "ClusterId": "standings-cluster",
        "Match": {
          "Path": "/standings/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "fixtures-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://fixtures-service:8080"
          }
        }
      },
      "teams-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://team-service:8080"
          }
        }
      },
      "roster-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://roster-service:8080"
          }
        }
      },
      "standings-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://standings-service:8080"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://notifications-service:8080"
          }
        }
      }
    }
  }
}